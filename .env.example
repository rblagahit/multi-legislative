# ─────────────────────────────────────────────────────────────────────────────
# Firebase Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase project credentials
# Found in: Firebase Console → Project Settings → Your Apps → SDK setup
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# LGU identifier used in Firestore paths (e.g., lgus/{LGU_ID}/...)
VITE_LGU_ID=sb-argao

# Firebase App Check — reCAPTCHA v3
# Register your site at: https://www.google.com/recaptcha/admin/create
# Then add the key in: Firebase Console → App Check → Apps → Register
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
